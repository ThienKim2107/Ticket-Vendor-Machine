@{
    ViewData["Title"] = "Welcome";
}

<section class="idle-page" aria-label="Idle screen">
    <header class="idle-header">
        <span class="idle-brand">CityTransit</span>
        <div class="idle-lang" role="group" aria-label="Language">
            <svg class="idle-lang-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M2 12H22" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12 2C14.5013 4.73835 15.9228 8.29203 16 12C15.9228 15.708 14.5013 19.2616 12 22C9.49872 19.2616 8.07725 15.708 8 12C8.07725 8.29203 9.49872 4.73835 12 2Z" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>English / Tiếng Việt</span>
        </div>
    </header>

    <div class="idle-decor" aria-hidden="true">
        <div class="idle-blur idle-blur--a"></div>
        <div class="idle-blur idle-blur--b"></div>
        <div class="idle-gradient"></div>
    </div>

    <div class="idle-main">
        <div class="idle-identity">
            <h1 class="idle-heading">WELCOME TO KIOSK</h1>
            <p class="idle-sub">Seamless city travel starts here. Tap the button below to begin your journey.</p>
        </div>

        <a class="idle-start" asp-controller="Ticket" asp-action="SelectDestination" aria-label="Start booking">
            <span class="idle-start-touch">
                <span class="idle-start-touch-text">START</span>
            </span>
        </a>

        <div class="idle-bento">
            <article class="idle-card">
                <div class="idle-card-icon" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 16C4 14.8954 4.89543 14 6 14H18C19.1046 14 20 14.8954 20 16V18H4V16Z" stroke="currentColor" stroke-width="1.5"/><path d="M6 14L7 6H17L18 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="7.5" cy="19" r="1.5" fill="currentColor"/><circle cx="16.5" cy="19" r="1.5" fill="currentColor"/></svg>
                </div>
                <h3>Bus Tracking</h3>
                <p>Real-time arrival updates</p>
            </article>
            <article class="idle-card idle-card--accent">
                <div class="idle-card-icon" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 10H21" stroke="currentColor" stroke-width="1.5"/><path d="M7 15H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
                <h3>Easy Payments</h3>
                <p>Contactless cards &amp; NFC</p>
            </article>
            <article class="idle-card">
                <div class="idle-card-icon" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 21C16.4183 21 20 17.4183 20 13C20 8.58172 16.4183 3 12 3C7.58172 3 4 8.58172 4 13C4 17.4183 7.58172 21 12 21Z" stroke="currentColor" stroke-width="1.5"/><path d="M9 10L12 13L15 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <h3>Route Finder</h3>
                <p>AI-powered path planning</p>
            </article>
        </div>
    </div>

    <div class="idle-statusbar">
        <span class="idle-status-dot" aria-hidden="true"></span>
        <span class="idle-status-text">System online 24/7</span>
    </div>
</section>
